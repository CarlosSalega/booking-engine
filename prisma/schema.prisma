generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================================================================
// Better Auth core models
// Field names match Better Auth v1.6.19 prisma-adapter expectations
// (see @better-auth/core db get-tables).
// =========================================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("PATIENT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  professional Professional?
  patient      Patient?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =========================================================================
// Business domain models
// Field types and defaults mirror the values defined in the corresponding
// domain modules (BookingStatus, PaymentStatus, ProviderPaymentStatus, etc.).
// =========================================================================

model Professional {
  id             String   @id @default(uuid())
  organizationId String
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String   @default("ACTIVE") // ProfessionalStatus
  specialties    String[] @default([])
  license        String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings Booking[]
  services  Service[]

  @@index([organizationId])
  @@index([status])
}

model Patient {
  id             String   @id @default(uuid())
  organizationId String
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String   @default("ACTIVE") // PatientStatus
  phone          String?
  address        String?
  dateOfBirth    DateTime?
  notes          String?
  // `createdByUserId` is a plain string column — NOT a Prisma relation.
  // Rationale: Better Auth's `User` model already has a `patient Patient?`
  // relation through `userId`. A second `@relation` on `createdByUserId`
  // would create a circular reference that Better Auth's prisma-adapter
  // may not handle cleanly. The column is audit-only: if the referenced
  // user is deleted, the UI shows "Desconocido". No cascade needed.
  createdByUserId String
  documentId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[]

  @@index([organizationId])
  @@index([status])
  @@index([documentId])
  @@index([createdByUserId])
}

model Service {
  id              String       @id @default(uuid())
  organizationId  String
  professionalId  String
  professional    Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int          @default(30)
  price           Float        @default(0)
  depositAmount   Float?
  paymentType     String       @default("NONE") // PaymentType
  paymentStatus   String       @default("PENDING") // PaymentStatus from services-domain
  status          String       @default("ACTIVE") // ServiceStatus
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  bookings Booking[]

  @@index([organizationId])
  @@index([professionalId])
  @@index([status])
}

model Booking {
  id             String       @id @default(uuid())
  organizationId String
  patientId      String?
  patient        Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status         String       @default("PENDING") // BookingStatus
  startTime      DateTime
  endTime        DateTime
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  payments Payment[]

  @@index([organizationId])
  @@index([patientId])
  @@index([professionalId])
  @@index([status])
  @@index([startTime])
}

model Payment {
  id                String   @id @default(uuid())
  organizationId    String
  bookingId         String
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider          String   @default("MERCADOPAGO") // PaymentProvider
  status            String   @default("PENDING") // ProviderPaymentStatus
  amount            Float
  preferenceId      String?
  externalReference String?
  retryCount        Int      @default(0)
  parentPaymentId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([bookingId])
  @@index([status])
}
